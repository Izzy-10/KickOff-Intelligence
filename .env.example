# IBM Granite API Key (Primary)
# Get from: https://cloud.ibm.com
IBM_GRANITE_API_KEY=your_ibm_granite_api_key_here

# Anthropic Claude API Key (Fallback)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: API Endpoint Configuration
# IBM_GRANITE_ENDPOINT=https://api.us-south.watsonx.cloud.ibm.com/ml/v1/text/generation
# ANTHROPIC_ENDPOINT=https://api.anthropic.com/v1/messages
